# ─── LLM Provider Keys ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── Search API Keys (at least one required) ───
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# ─── Content Fetching (Tier 2: Firecrawl for JS rendering + anti-bot) ───
FIRECRAWL_API_KEY=
# Optional: self-hosted Firecrawl instance URL (default: https://api.firecrawl.dev)
# FIRECRAWL_BASE_URL=http://localhost:3002

# ─── LinkedIn Structured Enrichment (Bright Data) ───
BRIGHTDATA_API_KEY=

# ─── App Config ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── LLM Model (optional, defaults to claude-haiku-4-5-20251001) ───
LLM_MODEL=
